{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/:path(.*)", "has": [{ "type": "host", "value": "www.raporton.pl" }], "destination": "https://raporton.pl/:path", "permanent": true }
  ],
  "rewrites": [
    { "source": "/regulamin", "destination": "/regulamin.html" },
    { "source": "/prywatnosc", "destination": "/prywatnosc.html" },
    { "source": "/kontakt", "destination": "/kontakt.html" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
